# Secret Bridge — Local Secrets
#
# Copy this file to secrets.local.env and fill in your keys:
#   cp secrets.template.env secrets.local.env
#
# DO NOT commit secrets.local.env to git.
#
# Usage:
#   node .secret-bridge/run-with-secrets.mjs -- <command>
#   node .secret-bridge/run-with-secrets.mjs --require OPENAI_API_KEY -- <command>
#   node .secret-bridge/run-with-secrets.mjs --require OPENAI_API_KEY,GITHUB_TOKEN -- <command>
#   node .secret-bridge/run-with-secrets.mjs --check OPENAI_API_KEY

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GITHUB_TOKEN=
HF_TOKEN=

# Uncomment and fill as needed:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# GOOGLE_API_KEY=
# SLACK_BOT_TOKEN=
# DATABASE_URL=
